---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description || ''}>
  <article>
    <h1>{post.data.title}</h1>

    <div class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('ja-JP', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      {post.data.author && (
        <span class="author">著者: {post.data.author}</span>
      )}
    </div>

    {post.data.categories && post.data.categories.length > 0 && (
      <div class="post-categories">
        <strong>カテゴリー:</strong>
        {post.data.categories.map((cat: string) => (
          <span class="category">{cat}</span>
        ))}
      </div>
    )}

    <div class="post-content">
      <Content />
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="post-tags">
        <strong>タグ:</strong>
        {post.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <div class="post-navigation">
      <a href="/blog" class="back-link">← ブログに戻る</a>
    </div>
  </article>
</BaseLayout>

<style>
  article h1 {
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e2e8f0;
    font-size: 0.95rem;
    color: #718096;
  }

  time {
    font-weight: 600;
    color: #4a5568;
  }

  .post-categories {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .category {
    display: inline-block;
    background: #eef2ff;
    color: #3730a3;
    padding: 0.35rem 0.85rem;
    border-radius: 5px;
  }

  .post-content {
    line-height: 1.8;
    margin: 2rem 0;
  }

  .post-content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid #3182ce;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #4a5568;
    font-style: italic;
  }

  .post-content :global(pre) {
    background-color: #f0f0f0 !important;
    color: #ff6b35 !important;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid #e0e0e0;
    font-weight: bold;
  }

  .post-content :global(code) {
    color: #ff6b35 !important;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 0.9rem;
    font-weight: bold;
  }

  .post-content :global(.astro-code) {
    background-color: #f0f0f0 !important;
    color: #ff6b35 !important;
  }

  .post-content :global(.astro-code span) {
    color: #ff6b35 !important;
    font-weight: bold;
  }

  /* Override all inline color styles in code blocks */
  .post-content :global(.astro-code [style*="color"]) {
    color: #ff6b35 !important;
    font-weight: bold;
  }

  .post-content :global(iframe) {
    width: 100%;
    max-width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    display: block;
    margin: 1.5rem 0;
  }

  /* Table of Contents Styles - Markdown format */
  .post-content > :global(h2:nth-of-type(1)) {
    border: none;
    background: none;
    padding: 0;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    color: #5ca9f7;
    font-weight: 700;
  }

  .post-content > :global(h2:nth-of-type(1)) + :global(ol) {
    border: 1px solid #cfcfcf;
    padding: 1.5rem;
    background: #fffef6;
    margin: 1.5rem 0;
    border-radius: 4px;
    list-style: none;
  }

  .post-content > :global(h2:nth-of-type(1)) + :global(ol) :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content > :global(h2:nth-of-type(1)) + :global(ol) :global(li) :global(a) {
    color: #5ca9f7;
    text-decoration: none;
  }

  .post-content > :global(h2:nth-of-type(1)) + :global(ol) :global(li) :global(a:hover) {
    text-decoration: underline;
  }

  .post-content > :global(h2:nth-of-type(1)) + :global(ol) :global(ul) {
    list-style: none;
    margin: 0.5rem 0 0 2rem;
    padding: 0;
  }

  .post-content > :global(h2:nth-of-type(1)) + :global(ol) :global(ul) :global(li) {
    margin-bottom: 0.25rem;
  }

  /* Heading styles with borders */
  .post-content :global(h2) {
    border-left: 5px solid #205a97;
    background-color: #f2f2f2;
    padding: 0.75rem 0 0.75rem 1rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 6rem;
  }

  .post-content :global(h2:nth-of-type(1)) {
    border: none;
    background: none;
    padding: 0;
  }

  .post-content :global(h3) {
    border-bottom: solid 2px #205a97;
    padding-bottom: 0.5rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 6rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
  }

  .tag {
    display: inline-block;
    background: #f7fafc;
    color: #2d3748;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #cbd5e0;
  }

  .post-navigation {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
  }

  .back-link {
    color: #3182ce;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s;
  }

  .back-link:hover {
    color: #1a365d;
    text-decoration: underline;
  }
</style>
